# at-mesh configuration
# Copy to .env and fill in values

ATMESH_HOSTNAME=mesh.glados.computer
ATMESH_ADDR=:9090
ATMESH_JWK_PATH=/data/keys/jwk.key
ATMESH_DB_NAME=/data/atmesh.db

# Headscale integration (optional, for revocation)
ATMESH_HEADSCALE_URL=https://headscale.glados.computer
ATMESH_HEADSCALE_KEY=

# OAuth client registration (required for Headscale)
ATMESH_CLIENT_ID=headscale
ATMESH_CLIENT_SECRET=
ATMESH_CLIENT_REDIRECT_URI=

# WebFinger (for Tailscale SaaS compat)
ATMESH_ADMIN_EMAIL=admin@mesh.glados.computer

ATMESH_SESSION_SECRET=change-me-in-production
ATMESH_LOG_LEVEL=info
